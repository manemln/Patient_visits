    elif graph_option == "High Risk Patients":
        threshold = st.number_input("Risk Threshold:", min_value=0.0, max_value=1.0, value=0.7)
        if st.button("Show High Risk Patients"):
            high_risk = engine.high_risk_patients(threshold)
            st.json(high_risk)

