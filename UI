class DataStorage:
    def __init__(self, path):
        self.path = path
        self.records = {}

    def load_data(self):
        try:
            with open(self.path, "r") as f:
                reader = csv.DictReader(f)
                for row in reader:
                    # Type conversion (important for AVL and Graph keys)
                    try:
                        row["visit_id"] = int(row["visit_id"])
                        row["patient_id"] = int(row["patient_id"])
                        row["doctor_id"] = int(row["doctor_id"])
                        row["treatment_cost"] = float(row["treatment_cost"])
                        row["number_of_visits"] = int(row["number_of_visits"])
                        row["risk_score"] = float(row["risk_score"])
                        row["outcome_score"] = float(row["outcome_score"])
                        # Handle 'referral_doctor' as int/None
                        try:
                             row['referral_doctor'] = int(row['referral_doctor'])
                        except ValueError:
                             row['referral_doctor'] = None # No referral

                        self.records[row["visit_id"]] = row
                    except ValueError as e:
                        st.error(f"Skipping row due to data type error: {e} in row {row}")
                        continue


            st.success(f"Loaded {len(self.records)} records.")
        except FileNotFoundError:
             st.error(f"File not found at path: {self.path}. Please provide a valid CSV file.")
             return

    def get_all(self):
        return self.records

# AVL TREE on stored dataset
class AVLNode:

    def __init__(self, key, record_ids):
        self.key = key
        self.record_ids = record_ids
        self.height = 1
        self.left = None
        self.right = None

class AVLTree:
   
    def __init__(self):
        self.root = None

    def get_height(self, node):
        return node.height if node else 0

    def get_balance(self, node):
        return self.get_height(node.left) - self.get_height(node.right)

    def update_height(self, node):
        node.height = 1 + max(self.get_height(node.left),
                              self.get_height(node.right))

    def rotate_left(self, x):
        y = x.right
        T2 = y.left

        y.left = x
        x.right = T2

        self.update_height(x)
        self.update_height(y)

        return y

    def rotate_right(self, x):
        y = x.left
        T3 = y.right

        y.right = x
        x.left = T3

        self.update_height(x)
        self.update_height(y)

        return y

    def insert(self, node, key, record_id):
        if not node:
            return AVLNode(key, [record_id])

        if key < node.key:
            node.left = self.insert(node.left, key, record_id)
        elif key > node.key:
            node.right = self.insert(node.right, key, record_id)
        else:
            node.record_ids.append(record_id)
            return node

        self.update_height(node)
        balance = self.get_balance(node)

        # Single left rotation, 3 nodes: left child of left child
        if balance > 1 and key < node.left.key:
            return self.rotate_right(node)

        # Single rotation for right
        if balance < -1 and key > node.right.key:
            return self.rotate_left(node)

        # Double rotation 3 nodes: left child then right child
        if balance > 1 and key > node.left.key:
            node.left = self.rotate_left(node.left)
            return self.rotate_right(node)

        # Double rotation 3 nodes: right child then left child
        if balance < -1 and key < node.right.key:
            node.right = self.rotate_right(node.right)
            return self.rotate_left(node)

        return node

    def add(self, key, record_id):
        self.root = self.insert(self.root, key, record_id)

    def search(self, key):
        node = self.root
        while node:
            if key < node.key:
                node = node.left
            elif key > node.key:
                node = node.right
            else:
                return list(node.record_ids)
        return []

    def delete(self, node, key, record_id):
        if not node:
            return None

        if key < node.key:
            node.left = self.delete(node.left, key, record_id)
        elif key > node.key:
            node.right = self.delete(node.right, key, record_id)
        else:
            if record_id in node.record_ids:
                node.record_ids.remove(record_id)

            if len(node.record_ids) > 0:
                return node

            if not node.left:
                return node.right
            if not node.right:
                return node.left

            successor = node.right
            while successor.left:
                successor = successor.left
            node.key = successor.key
            node.record_ids = successor.record_ids
            node.right = self.delete(node.right, successor.key, successor.record_ids[0])

        self.update_height(node)
        balance = self.get_balance(node)

        if balance > 1 and self.get_balance(node.left) >= 0:
            return self.rotate_right(node)

        if balance > 1 and self.get_balance(node.left) < 0:
            node.left = self.rotate_left(node.left)
            return self.rotate_right(node)

        if balance < -1 and self.get_balance(node.right) <= 0:
            return self.rotate_left(node)

        if balance < -1 and self.get_balance(node.right) > 0:
            node.right = self.rotate_right(node.right)
            return self.rotate_left(node)

        return node

    def remove(self, key, record_id):
        self.root = self.delete(self.root, key, record_id)

    def inorder_keys_within_range(self, node, low, high, result):
        if not node:
            return

        if node.key >= low:
            self.inorder_keys_within_range(node.left, low, high, result)

        if low <= node.key <= high:
            for visit_id in node.record_ids:
                result.append(visit_id)

        if node.key <= high:
            self.inorder_keys_within_range(node.right, low, high, result)


# CLASS INDEX MANAGER for building AVLs and using them
class IndexManager:
    # ... (Keep the original IndexManager class content here) ...
    def __init__(self):
        self.by_patient = AVLTree()
        self.by_doctor = AVLTree()
        self.by_cost = AVLTree()
        self.by_visit = AVLTree()
        self.storage = {}

    def build(self, storage):
        self.storage = storage
        for visit_id, record in storage.items():
            self.by_patient.add(record["patient_id"], visit_id)
            self.by_doctor.add(record["doctor_id"], visit_id)
            self.by_cost.add(record["treatment_cost"], visit_id)
            self.by_visit.add(visit_id, visit_id)

    def find_by_patient(self, patient_id):
        return self.by_patient.search(patient_id)

    def find_by_doctor(self, doctor_id):
        return self.by_doctor.search(doctor_id)

    def find_by_cost(self, cost):
        return self.by_cost.search(cost)

    def find_by_visit(self, visit_id):
        return self.by_visit.search(visit_id)

    def find_by_cost_range(self, low, high):
        result = []
        self.by_cost.inorder_keys_within_range(self.by_cost.root, low, high, result)
        return result

    def add_record(self, record):
        visit_id = record["visit_id"]

        if len(self.by_visit.search(visit_id)) > 0:
            st.warning(f"Duplicate visit_id {visit_id}. Record rejected.")
            return None

        self.storage[visit_id] = record

        self.by_patient.add(record["patient_id"], visit_id)
        self.by_doctor.add(record["doctor_id"], visit_id)
        self.by_cost.add(record["treatment_cost"], visit_id)
        self.by_visit.add(visit_id, visit_id)

        return record

    def delete_record(self, visit_id):
        record = self.storage.pop(visit_id, None)
        if not record:
            return None

        self.by_patient.remove(record["patient_id"], visit_id)
        self.by_doctor.remove(record["doctor_id"], visit_id)
        self.by_cost.remove(record["treatment_cost"], visit_id)
        self.by_visit.remove(visit_id, visit_id)

        return record

    def modify_record(self, visit_id, field, new_value):
        record = self.storage.get(visit_id)
        if not record:
            st.warning(f"Visit {visit_id} not found.")
            return False

        old_value = record[field]
        if old_value == new_value:
            return record

        if field == "patient_id":
            self.by_patient.remove(old_value, visit_id)
            self.by_patient.add(new_value, visit_id)
        elif field == "doctor_id":
            self.by_doctor.remove(old_value, visit_id)
            self.by_doctor.add(new_value, visit_id)
        elif field == "treatment_cost":
            self.by_cost.remove(old_value, visit_id)
            self.by_cost.add(new_value, visit_id)

        record[field] = new_value

        return record

# GRAPH
class Vertex:
    # ... (Keep the original Vertex class content here) ...
    def __init__(self, visit_id, element=None):
        self.visit_id = visit_id
        self.element = element
        self.color = "white"
        self.distance = float('inf')
        self.predecessor = None
        self.discovery_time = 0
        self.finish_time = 0

    def get_element(self):
        return self.element

    def __str__(self):
        return f"Vertex(visit_id={self.visit_id})"

class Edge:
    # ... (Keep the original Edge class content here) ...
    def __init__(self, origin, destination, element=None):
        self.origin = origin
        self.destination = destination
        self.element = element

    def endpoints(self):
        return (self.origin, self.destination)

    def opposite(self, vertex):
        if vertex == self.origin:
            return self.destination
        elif vertex == self.destination:
            return self.origin
        else:
            raise ValueError("Vertex not incident to this edge")

    def get_element(self):
        return self.element

    def __str__(self):
        return f"Edge({self.origin.visit_id} -> {self.destination.visit_id})"

class Graph:
    # ... (Keep the original Graph class content, especially BFS, DFS, find_path) ...
    def __init__(self, directed=True):
        self.directed = directed
        self.vertices = {}
        self.outgoing = {}
        self.incoming = {}

    def num_vertices(self):
        return len(self.vertices)

    def num_edges(self):
        total = sum(len(edges) for edges in self.outgoing.values())
        return total

    def get_vertices(self):
        return self.vertices.values()

    def get_edges(self):
        edges = []
        for vertex_edges in self.outgoing.values():
            edges.extend(vertex_edges.values())
        return edges

    def get_vertex(self, visit_id):
        return self.vertices.get(visit_id)

    def insert_vertex(self, visit_id, element=None):
        if visit_id in self.vertices:
            return self.vertices[visit_id]

        v = Vertex(visit_id, element)
        self.vertices[visit_id] = v
        self.outgoing[v] = {}
        self.incoming[v] = {}
        return v

    def insert_edge(self, u, v, element=None):
        if isinstance(u, int):
            if u not in self.vertices:
                u = self.insert_vertex(u)
            else:
                u = self.vertices[u]

        if isinstance(v, int):
            if v not in self.vertices:
                v = self.insert_vertex(v)
            else:
                v = self.vertices[v]

        if v in self.outgoing[u]:
            return self.outgoing[u][v]

        e = Edge(u, v, element)
        self.outgoing[u][v] = e
        self.incoming[v][u] = e

        return e

    def outgoing_edges(self, v):
        if isinstance(v, int):
            v = self.vertices.get(v)
        return self.outgoing.get(v, {})

    def incoming_edges(self, v):
        if isinstance(v, int):
            v = self.vertices.get(v)
        return self.incoming.get(v, {})

    def BFS(self, start_visit_id):
        for vertex in self.vertices.values():
            vertex.color = "white"
            vertex.distance = float('inf')
            vertex.predecessor = None

        start = self.vertices.get(start_visit_id)
        if start is None:
            return {}

        start.color = "gray"
        start.distance = 0
        start.predecessor = None

        queue = deque([start]) # Use deque for efficiency
        distances = {start.visit_id: 0}

        while queue:
            u = queue.popleft()
            for v in self.outgoing[u].keys():
                if v.color == "white":
                    v.color = "gray"
                    v.distance = u.distance + 1
                    v.predecessor = u
                    distances[v.visit_id] = v.distance
                    queue.append(v)
            u.color = "black"

        return distances

    def find_path(self, start_visit_id, end_visit_id):
        self.BFS(start_visit_id)

        end = self.vertices.get(end_visit_id)
        if end is None or end.distance == float('inf'):
            return []

        path = []
        current = end
        while current is not None:
            path.append(current.visit_id)
            current = current.predecessor

        path.reverse()
        return path

# GRAPH MANAGER
class GraphManager:
    # ... (Keep the original GraphManager class content) ...
    def __init__(self):
        self.graph = Graph(directed=True)
        self.storage = None

    def build_from_records(self, storage, index_manager):
        self.storage = storage

        for visit_id, record in storage.items():
            self.graph.insert_vertex(visit_id, record)

        edges_created = 0

        for visit_id, record in storage.items():
            patient_id = record.get('patient_id')
            current_doctor = record.get('doctor_id')
            referral_doctor = record.get('referral_doctor')

            if referral_doctor and referral_doctor != current_doctor:
                patient_visits = index_manager.find_by_patient(patient_id)

                for other_visit_id in patient_visits:
                    if other_visit_id == visit_id:
                        continue

                    other_record = storage[other_visit_id]

                    if other_record['doctor_id'] == referral_doctor:
                        self.graph.insert_edge(
                            visit_id,
                            other_visit_id,
                            element={
                                'referral_doctor': referral_doctor,
                                'original_doctor': current_doctor,
                                'patient_id': patient_id
                            }
                        )
                        edges_created += 1
                        break
        return self.graph.num_vertices(), edges_created

    def find_referral_chain(self, visit_id):
        vertex = self.graph.get_vertex(visit_id)
        if vertex is None:
            return []

        chain = []
        visited = set()
        current = vertex

        while current and current.visit_id not in visited:
            chain.insert(0, current.visit_id)
            visited.add(current.visit_id)

            incoming = self.graph.incoming_edges(current)
            if len(incoming) == 0:
                break

            predecessor = next(iter(incoming.keys()))
            current = predecessor

        return chain

    def find_all_referrals_from(self, visit_id):
        distances = self.graph.BFS(visit_id)
        # Exclude the start node itself from the list of referrals
        return [vid for vid in distances.keys() if vid != visit_id]

    def find_patient_journey(self, patient_id):
        if not self.storage:
            return []

        journey = []
        for visit_id, record in self.storage.items():
            if record['patient_id'] == patient_id:
                journey.append({
                    'visit_id': visit_id,
                    'doctor_id': record['doctor_id'],
                    'department': record['department'],
                    'diagnosis': record['diagnosis'],
                    'referral_doctor': record['referral_doctor']
                })
        # Sort by visit_id to approximate chronological order
        return sorted(journey, key=lambda x: x['visit_id'])


    def get_referral_statistics(self):
        stats = {
            'total_visits': self.graph.num_vertices(),
            'total_referral_edges': self.graph.num_edges(),
            'visits_that_led_to_referrals': 0,
            'visits_that_were_referred': 0,
            'max_referrals_from_one_visit': 0,
            'max_incoming_referrals': 0,
            'avg_referrals_per_visit': 0
        }

        total_out = 0

        for vertex in self.graph.get_vertices():
            out_deg = self.graph.outgoing_edges(vertex)
            in_deg = self.graph.incoming_edges(vertex)

            out_deg_count = len(out_deg)
            in_deg_count = len(in_deg)

            if out_deg_count > 0:
                stats['visits_that_led_to_referrals'] += 1
                stats['max_referrals_from_one_visit'] = max(
                    stats['max_referrals_from_one_visit'], out_deg_count)

            if in_deg_count > 0:
                stats['visits_that_were_referred'] += 1
                stats['max_incoming_referrals'] = max(
                    stats['max_incoming_referrals'], in_deg_count)

            total_out += out_deg_count

        if stats['total_visits'] > 0:
            stats['avg_referrals_per_visit'] = total_out / stats['total_visits']

        return stats

