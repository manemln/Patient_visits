import sys
import os
sys.path.append(os.path.abspath(os.path.join(os.path.dirname(__file__), '..')))


import streamlit as st
st.set_page_config(page_title="Patient Visits", layout="wide")

from core.storage import DataStorage
from core.indexing import IndexManager
from core.graph import GraphManager
from core.query_engine import QueryEngine
import pandas as pd

# -------------------- Load Data and Initialize --------------------
@st.cache_data(show_spinner=True)
def load_system(sample_size=100000):
    df = pd.read_csv("data/patient_visits.csv")
    subset_df = df.head(sample_size)
    subset_df.to_csv("data/patient_visits_subset.csv", index=False)

    storage = DataStorage("data/patient_visits_subset.csv")
    storage.load_data()

    index_manager = IndexManager()
    index_manager.build(storage.get_all())

    graph_manager = GraphManager()
    graph_manager.build_from_records(storage.get_all(), index_manager)

    engine = QueryEngine(index_manager.storage, index_manager, graph_manager)
    return storage, index_manager, graph_manager, engine

storage, index_manager, graph_manager, engine = load_system()

# -------------------- Streamlit UI --------------------
st.title("🩺 Patient Visits System")

st.sidebar.header("Navigation")
menu_option = st.sidebar.radio("Choose Operation", [
    "Search / Queries",
    "Add / Modify / Delete",
    "Analytics",
    "Graph Analysis",
    "Traversals (BFS / DFS)"
])

# -------------------- Search / Queries --------------------
if menu_option == "Search / Queries":
    st.header("🔍 Search / Query Operations")
    search_option = st.selectbox("Select Query Type", [
        "Find by Patient ID",
        "Find by Visit ID",
        "Find by Doctor ID",
        "Find by Cost",
        "Find by Cost Range"
    ])

    if search_option == "Find by Patient ID":
        patient_id = st.number_input("Patient ID:", min_value=1, value=1)
        if st.button("Search Patient"):
            results = engine.find_by_patient(patient_id)
            st.write(f"Found {len(results)} visits for Patient {patient_id}")
            st.dataframe(results)

    elif search_option == "Find by Visit ID":
        visit_id = st.number_input("Visit ID:", min_value=1, value=1)
        if st.button("Search Visit"):
            results = engine.find_by_visit(visit_id)
            st.write(f"Visit details for ID {visit_id}")
            st.dataframe(results)

    elif search_option == "Find by Doctor ID":
        doctor_id = st.number_input("Doctor ID:", min_value=1, value=1)
        if st.button("Search Doctor"):
            results = engine.find_by_doctor(doctor_id)
            st.write(f"Found {len(results)} visits for Doctor {doctor_id}")
            st.dataframe(results)

    elif search_option == "Find by Cost":
        cost = st.number_input("Exact Cost:", min_value=0.0, value=0.0)
        if st.button("Search Cost"):
            results = engine.find_by_cost(cost)
            st.write(f"Found {len(results)} visits with cost {cost}")
            st.dataframe(results)

    elif search_option == "Find by Cost Range":
        low = st.number_input("Min Cost:", min_value=0.0, value=0.0)
        high = st.number_input("Max Cost:", min_value=0.0, value=1000.0)
        if st.button("Search Cost Range"):
            results = engine.find_by_cost_range(low, high)
            st.write(f"Found {len(results)} visits with cost between {low} and {high}")
            st.dataframe(results)

# -------------------- Add / Modify / Delete --------------------
elif menu_option == "Add / Modify / Delete":
    st.header("✏️ Add / Modify / Delete Records")
    action = st.selectbox("Action", ["Add", "Modify", "Delete"])
    
    if action == "Add":
        st.subheader("Add Record")
        new_record = {}
        new_record["visit_id"] = st.number_input("Visit ID:", min_value=1, value=1)
        new_record["patient_id"] = st.number_input("Patient ID:", min_value=1, value=1)
        new_record["doctor_id"] = st.number_input("Doctor ID:", min_value=1, value=1)
        new_record["department"] = st.text_input("Department:", value="General")
        new_record["diagnosis"] = st.text_input("Diagnosis:", value="")
        new_record["treatment_cost"] = st.number_input("Treatment Cost:", min_value=0.0, value=0.0)
        new_record["number_of_visits"] = st.number_input("Number of Visits:", min_value=1, value=1)
        new_record["risk_score"] = st.number_input("Risk Score:", min_value=0.0, max_value=1.0, value=0.0)
        new_record["outcome_score"] = st.number_input("Outcome Score:", min_value=0.0, max_value=1.0, value=0.0)
        new_record["referral_doctor"] = st.number_input("Referral Doctor ID (optional):", min_value=0, value=0)
        
        if st.button("Add Record"):
            added = engine.add_record(new_record)
            if added:
                st.success(f"Visit {new_record['visit_id']} added!")
            else:
                st.error("Failed to add record (duplicate visit_id?).")
    
    elif action == "Modify":
        st.subheader("Modify Record")
        vid_mod = st.number_input("Visit ID to Modify:", min_value=1, value=1)
        field = st.selectbox("Field to Modify", [
            "patient_id", "doctor_id", "department", "diagnosis",
            "treatment_cost", "number_of_visits", "risk_score", "outcome_score", "referral_doctor"
        ])
        new_value = st.text_input("New Value:")
        if st.button("Modify Record"):
            # Convert types
            if field in ["patient_id", "doctor_id", "number_of_visits", "referral_doctor"]:
                new_value = int(new_value)
            elif field in ["treatment_cost", "risk_score", "outcome_score"]:
                new_value = float(new_value)
            modified = engine.modify_record(vid_mod, field, new_value)
            if modified:
                st.success(f"Visit {vid_mod} updated!")
                st.write(modified)
            else:
                st.error("Record not found.")
    
    elif action == "Delete":
        st.subheader("Delete Record")
        vid_del = st.number_input("Visit ID to Delete:", min_value=1, value=1)
        if st.button("Delete Record"):
            deleted = engine.delete_record(vid_del)
            if deleted:
                st.success(f"Visit {vid_del} deleted!")
            else:
                st.error("Record not found or already deleted.")

