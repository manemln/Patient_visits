                    st.success(f"Record for Visit ID {del_vid} deleted successfully.")
                    # Rebuild graph to remove the node
                    st.session_state.graph_manager.build_from_records(st.session_state.data_storage.get_all(), st.session_state.index_manager)
                    st.session_state.data_loaded = True
                else:
                    st.error(f"Visit ID {del_vid} not found.")

    # --- TAB 3: Referral Network Analysis ---
    with tab3:
        st.header("Referral Network Analysis (Graph Manager)")

        st.subheader("Network Statistics")
        stats = st.session_state.graph_manager.get_referral_statistics()
        col1, col2, col3 = st.columns(3)
        col1.metric("Total Visits (Nodes)", stats['total_visits'])
        col2.metric("Total Referrals (Edges)", stats['total_referral_edges'])
        col3.metric("Avg. Referrals / Visit", f"{stats['avg_referrals_per_visit']:.2f}")

        st.subheader("Patient Journey & Referral Chains")
        analysis_type = st.radio("Select Analysis:", ("Patient Journey", "Referral Chain to Visit", "Referrals FROM Visit", "Shortest Path"))

        if analysis_type == "Patient Journey":
            p_id_j = st.number_input("Enter Patient ID for Journey:", min_value=1, format="%d", key='j_pid')
            if st.button("Show Patient Journey"):
                journey = st.session_state.graph_manager.find_patient_journey(p_id_j)
                if journey:
                    st.success(f"Found {len(journey)} steps in Patient {p_id_j}'s journey.")
                    st.dataframe(pd.DataFrame(journey))
                else:
                    st.warning("No journey found for this patient.")

        elif analysis_type == "Referral Chain to Visit":
            v_id_c = st.number_input("Enter Visit ID to trace chain back to:", min_value=1, format="%d", key='c_vid')
            if st.button("Trace Referral Chain"):
                chain = st.session_state.graph_manager.find_referral_chain(v_id_c)
                if chain:
                    st.success(f"Chain found (Length: {len(chain)}):")
                    st.code(" -> ".join(map(str, chain)))
                else:
                    st.warning("No referral chain found for this visit.")

        elif analysis_type == "Referrals FROM Visit":
            v_id_r = st.number_input("Enter Visit ID to find all subsequent referrals:", min_value=1, format="%d", key='r_vid')
            if st.button("Find All Referred Visits"):
                referred_visits = st.session_state.graph_manager.find_all_referrals_from(v_id_r)
                if referred_visits:
                    st.success(f"This visit led to {len(referred_visits)} subsequent referrals (direct/indirect).")
                    st.dataframe(pd.DataFrame([st.session_state.data_storage.get_all()[v] for v in referred_visits]))
                else:
                    st.warning("This visit did not lead to any subsequent recorded referrals.")

        elif analysis_type == "Shortest Path":
            col_sp1, col_sp2 = st.columns(2)
            start_v_id = col_sp1.number_input("Start Visit ID:", min_value=1, format="%d", key='sp_start')
            end_v_id = col_sp2.number_input("End Visit ID:", min_value=1, format="%d", key='sp_end')
            if st.button("Find Shortest Referral Path"):
                path = st.session_state.graph_manager.graph.find_path(start_v_id, end_v_id)
                if path:
                    st.success(f"Shortest path found (Length: {len(path)} visits):")
                    st.code(" -> ".join(map(str, path)))
                else:
                    st.warning("No path found between these two visits.")

