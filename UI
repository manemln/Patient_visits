# -------------------- Traversals (BFS / DFS) --------------------
elif menu_option == "Traversals (BFS / DFS)":
    st.header("⚡ Traversals")
    
    traversal = st.selectbox("Traversal Type", ["BFS from Visit", "DFS Discovery / Finish Times"])
    
    if traversal == "BFS from Visit":
        vid = st.number_input("Starting Visit ID:", min_value=1, value=1)
        if st.button("Run BFS"):
            distances = engine.bfs_from_visit(vid)
            if distances:
                df = pd.DataFrame(list(distances.items()), columns=["Visit ID", "Distance"])
                df = df.sort_values("Distance")
                st.dataframe(df)
            else:
                st.warning("Visit ID not found in graph.")
    
    elif traversal == "DFS Discovery / Finish Times":
        if st.button("Run DFS"):
            times = engine.dfs_times()
            if times:
                df = pd.DataFrame([
                    {"Visit ID": vid, "Discovery Time": t[0], "Finish Time": t[1]} 
                    for vid, t in times.items()
                ])
                df = df.sort_values("Discovery Time")
                st.dataframe(df)
            else:
                st.warning("Graph is empty.")
