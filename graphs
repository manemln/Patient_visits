
#GRAPH
class Vertex:
    #vertex in the graph (a visit_id)
    def __init__(self, visit_id, element=None):
        self.visit_id = visit_id 
        self.element = element     # Can store additional data (the full record)
        self.color = "white"       # For BFS/DFS: white, gray, black
        self.distance = float('inf')  
        self.predecessor = None    # For BFS/DFS: parent in traversal tree
        self.discovery_time = 0    # For DFS: when vertex was discovered
        self.finish_time = 0       # For DFS: when vertex processing finished
    
    def get_element(self):
        return self.element
    
    def __str__(self):
        return f"Vertex(visit_id={self.visit_id})"

class Edge:
    #edge in the graph (referral relationship)
    def __init__(self, origin, destination, element=None):
        self.origin = origin         
        self.destination = destination 
        self.element = element         #Can store referral info(doctor_id,...)
    
    def endpoints(self):
        #gives tuple of (origin, destination)vertices
        return (self.origin, self.destination)
    
    def opposite(self, vertex):
        #returns the vertex opposite to the given vertex on this edge
        if vertex == self.origin:
            return self.destination
        elif vertex == self.destination:
            return self.origin
        else:
            raise ValueError("Vertex not incident to this edge")
    
    def get_element(self):
        return self.element
    
    def __str__(self):
        return f"Edge({self.origin.visit_id} -> {self.destination.visit_id})"

class Graph:
    #Adjacency Map representation of a directed graph
    def __init__(self, directed=True):
        self.directed = directed
        self.vertices = {}  # maps visit_id to Vertex object, {1:Vertex(1),...}
        #Adjacency map = vertex -> {opposite_vertex: Edge} 
        self.outgoing = {} #{opposites:edge}
        self.incoming = {} #{opposites:edge}
    
    #basic graph operations
    def num_vertices(self):
        return len(self.vertices)
    
    def num_edges(self):
        total = sum(len(edges) for edges in self.outgoing.values())
        return total if self.directed else total // 2
    
    def get_vertices(self):
        """Return an iterable of all vertices"""
        return self.vertices.values()
    
    def get_edges(self):
        """Return a set of all edges (avoid duplicates in undirected)"""
        edges = set()
        for vertex_edges in self.outgoing.values():
            edges.update(vertex_edges.values())
        return edges
    
    def get_vertex(self, visit_id):
        """Get vertex by visit_id"""
        return self.vertices.get(visit_id)
    
    def get_edge(self, u, v):
        """
        Return edge from vertex u to vertex v, or None if it doesn't exist.
        u and v can be Vertex objects or visit_ids
        """
        if isinstance(u, int):
            u = self.vertices.get(u)
        if isinstance(v, int):
            v = self.vertices.get(v)
        
        if u is None or v is None:
            return None
        
        return self.outgoing.get(u, {}).get(v)
    
    def degree(self, v, outgoing=True):
        """
        Return number of outgoing edges from v (or incoming if outgoing=False).
        For undirected graphs, these are the same.
        """
        if isinstance(v, int):
            v = self.vertices.get(v)
        
        adj_map = self.outgoing if outgoing else self.incoming
        return len(adj_map.get(v, {}))
    
    def out_degree(self, v):
        """Return number of outgoing edges from vertex v"""
        return self.degree(v, True)
    
    def in_degree(self, v):
        """Return number of incoming edges to vertex v"""
        return self.degree(v, False)
    
    def incident_edges(self, v, outgoing=True):
        """
        Return all outgoing (or incoming) edges from vertex v.
        Returns dictionary {opposite_vertex: edge}
        """
        if isinstance(v, int):
            v = self.vertices.get(v)
        
        adj_map = self.outgoing if outgoing else self.incoming
        return adj_map.get(v, {})
    
    def outgoing_edges(self, v):
        """Return dictionary of outgoing edges from v"""
        return self.incident_edges(v, True)
    
    def incoming_edges(self, v):
        """Return dictionary of incoming edges to v"""
        return self.incident_edges(v, False)
    
    # ==================== MODIFICATION OPERATIONS ====================
    
    def insert_vertex(self, visit_id, element=None):
        """Create and return a new Vertex storing visit_id"""
        if visit_id in self.vertices:
            return self.vertices[visit_id]
        
        v = Vertex(visit_id, element)
        self.vertices[visit_id] = v
        self.outgoing[v] = {}
        self.incoming[v] = {}
        return v
    
    def insert_edge(self, u, v, element=None):
        """
        Create and return a new Edge from vertex u to vertex v.
        u and v can be Vertex objects or visit_ids.
        element can store referral information (e.g., referring doctor_id)
        """
        # Convert visit_ids to Vertex objects if needed
        if isinstance(u, int):
            if u not in self.vertices:
                u = self.insert_vertex(u)
            else:
                u = self.vertices[u]
        
        if isinstance(v, int):
            if v not in self.vertices:
                v = self.insert_vertex(v)
            else:
                v = self.vertices[v]
        
        # Check if edge already exists
        if v in self.outgoing[u]:
            return self.outgoing[u][v]
        
        # Create the edge
        e = Edge(u, v, element)
        self.outgoing[u][v] = e
        self.incoming[v][u] = e
        
        return e
    
    def remove_vertex(self, v):
        """Remove vertex v and all its incident edges"""
        if isinstance(v, int):
            v = self.vertices.get(v)
        
        if v is None:
            return
        
        # Remove all outgoing edges
        for dest in list(self.outgoing[v].keys()):
            del self.incoming[dest][v]
        del self.outgoing[v]
        
        # Remove all incoming edges
        for origin in list(self.incoming[v].keys()):
            del self.outgoing[origin][v]
        del self.incoming[v]
        
        # Remove vertex itself
        del self.vertices[v.visit_id]
    
    def remove_edge(self, e):
        """Remove edge e from the graph"""
        u, v = e.endpoints()
        
        if v in self.outgoing.get(u, {}):
            del self.outgoing[u][v]
        
        if u in self.incoming.get(v, {}):
            del self.incoming[v][u]
    
    # ==================== GRAPH TRAVERSALS ====================
    
    def BFS(self, start_visit_id):
        """
        Breadth-First Search starting from start_visit_id.
        Returns dictionary: {visit_id: distance_from_start}
        Also sets vertex.color, vertex.distance, vertex.predecessor
        """
        # Initialize all vertices
        for vertex in self.vertices.values():
            vertex.color = "white"
            vertex.distance = float('inf')
            vertex.predecessor = None
        
        # Get start vertex
        start = self.vertices.get(start_visit_id)
        if start is None:
            print(f"Start vertex {start_visit_id} not found")
            return {}
        
        # Initialize start vertex
        start.color = "gray"
        start.distance = 0
        start.predecessor = None
        
        # Use a list as a queue (append to end, pop from beginning)
        queue = [start]
        distances = {start.visit_id: 0}
        
        while queue:
            u = queue.pop(0)  # Dequeue from front
            
            # Explore all adjacent vertices
            for v, edge in self.outgoing[u].items():
                if v.color == "white":  # Undiscovered
                    v.color = "gray"
                    v.distance = u.distance + 1
                    v.predecessor = u
                    distances[v.visit_id] = v.distance
                    queue.append(v)
            
            u.color = "black"  # Finished processing
        
        return distances
    
    def DFS(self):
        """
        Depth-First Search on entire graph.
        Returns dictionary: {visit_id: (discovery_time, finish_time)}
        Also sets vertex.color, vertex.discovery_time, vertex.finish_time, vertex.predecessor
        """
        # Initialize all vertices
        for vertex in self.vertices.values():
            vertex.color = "white"
            vertex.predecessor = None
            vertex.discovery_time = 0
            vertex.finish_time = 0
        
        time = [0]  # Use list to make it mutable in nested function
        times = {}
        
        def DFS_visit(u):
            time[0] += 1
            u.discovery_time = time[0]
            u.color = "gray"
            
            # Explore all adjacent vertices
            for v, edge in self.outgoing[u].items():
                if v.color == "white":
                    v.predecessor = u
                    DFS_visit(v)
            
            u.color = "black"
            time[0] += 1
            u.finish_time = time[0]
            times[u.visit_id] = (u.discovery_time, u.finish_time)
        
        # Visit all vertices (to handle disconnected components)
        for vertex in self.vertices.values():
            if vertex.color == "white":
                DFS_visit(vertex)
        
        return times
    
    def DFS_from_vertex(self, start_visit_id):
        """
        Depth-First Search starting from a specific vertex.
        Returns list of visit_ids in DFS order.
        """
        start = self.vertices.get(start_visit_id)
        if start is None:
            print(f"Start vertex {start_visit_id} not found")
            return []
        
        # Initialize
        for vertex in self.vertices.values():
            vertex.color = "white"
        
        dfs_order = []
        
        def DFS_visit(u):
            u.color = "gray"
            dfs_order.append(u.visit_id)
            
            for v, edge in self.outgoing[u].items():
                if v.color == "white":
                    DFS_visit(v)
            
            u.color = "black"
        
        DFS_visit(start)
        return dfs_order
    
    def find_path(self, start_visit_id, end_visit_id):
        """
        Find shortest path from start to end using BFS.
        Returns list of visit_ids representing the path, or empty list if no path exists.
        """
        # Run BFS from start
        self.BFS(start_visit_id)
        
        end = self.vertices.get(end_visit_id)
        if end is None or end.distance == float('inf'):
            return []  # No path exists
        
        # Reconstruct path by following predecessors backward
        path = []
        current = end
        while current is not None:
            path.append(current.visit_id)
            current = current.predecessor
        
        path.reverse()  # Reverse to get start -> end order
        return path
    
    def is_connected(self):
        """
        Check if graph is connected (for undirected) or weakly connected (for directed).
        Returns True if all vertices are reachable from any starting vertex.
        """
        if len(self.vertices) == 0:
            return True
        
        # Pick any vertex
        start = next(iter(self.vertices.values()))
        
        # Run DFS
        visited = set()
        
        def DFS_visit(u):
            visited.add(u.visit_id)
            for v in self.outgoing[u].keys():
                if v.visit_id not in visited:
                    DFS_visit(v)
        
        DFS_visit(start)
        return len(visited) == len(self.vertices)
    
    def topological_sort(self):
        """
        Perform topological sort on a directed acyclic graph (DAG).
        Returns list of visit_ids in topological order, or None if graph has cycles.
        """
        if not self.directed:
            print("Topological sort only works on directed graphs")
            return None
        
        # Run DFS to compute finish times
        times = self.DFS()
        
        # Sort vertices by decreasing finish time
        sorted_vertices = sorted(times.items(), key=lambda x: x[1][1], reverse=True)
        return [visit_id for visit_id, _ in sorted_vertices]
    
    def transpose(self):
        """
        Create and return the transpose of this graph (all edges reversed).
        Used for finding strongly connected components.
        """
        gt = Graph(directed=self.directed)
        
        # Add all vertices
        for visit_id, vertex in self.vertices.items():
            gt.insert_vertex(visit_id, vertex.element)
        
        # Add all edges in reverse direction
        for edge in self.get_edges():
            u, v = edge.endpoints()
            gt.insert_edge(v.visit_id, u.visit_id, edge.element)
        
        return gt
    
    def strongly_connected_components(self):
        """
        Find strongly connected components using Kosaraju's algorithm.
        Returns list of lists, where each inner list is a strongly connected component.
        """
        if not self.directed:
            print("SCC only applies to directed graphs")
            return None
        
        # Step 1: Run DFS on original graph to get finish times
        times = self.DFS()
        
        # Step 2: Create transpose graph
        gt = self.transpose()
        
        # Step 3: Run DFS on transpose in decreasing finish time order
        # Initialize
        for vertex in gt.vertices.values():
            vertex.color = "white"
        
        sccs = []
        
        def DFS_visit(u, component):
            u.color = "gray"
            component.append(u.visit_id)
            
            for v in gt.outgoing[u].keys():
                if v.color == "white":
                    DFS_visit(v, component)
            
            u.color = "black"
        
        # Visit vertices in decreasing finish time order
        sorted_vertices = sorted(times.items(), key=lambda x: x[1][1], reverse=True)
        
        for visit_id, _ in sorted_vertices:
            vertex = gt.vertices[visit_id]
            if vertex.color == "white":
                component = []
                DFS_visit(vertex, component)
                sccs.append(component)
        
        return sccs
    
    # ==================== UTILITY METHODS ====================
    
    def print_graph(self, limit=20):
        """Print graph structure (limited to first 'limit' vertices)"""
        print(f"\n{'='*60}")
        print(f"Graph: {'Directed' if self.directed else 'Undirected'}")
        print(f"Vertices: {self.num_vertices()}, Edges: {self.num_edges()}")
        print(f"{'='*60}")
        
        count = 0
        for visit_id, vertex in self.vertices.items():
            if count >= limit:
                print(f"... (showing first {limit} vertices only)")
                break
            
            out_edges = self.outgoing[vertex]
            if out_edges:
                neighbors = [str(v.visit_id) for v in out_edges.keys()]
                print(f"Visit {visit_id} -> {', '.join(neighbors)}")
            else:
                print(f"Visit {visit_id} -> (no outgoing edges)")
            count += 1
        print(f"{'='*60}\n")


# ==================== GRAPH MANAGER ====================

class GraphManager:
    """
    Manages the graph representation of medical referrals.
    Integrates with IndexManager to build graph from visit records.
    
    GRAPH BUILDING STRATEGY:
    - Vertices: Each visit_id is a vertex
    - Edges: Created based on doctor referrals between patients
    
    Logic: When patient P sees doctor D1 and gets referred to doctor D2,
    we find the visit where P sees D2 and create an edge from the original visit
    to the referred visit.
    """
    def __init__(self):
        self.graph = Graph(directed=True)
        self.storage = None
    
    def build_from_records(self, storage, index_manager):
        """
        Build graph from medical records using referral_doctor field.
        
        Strategy:
        1. Add all visits as vertices
        2. For each visit with a referral_doctor:
           - Find other visits by the same patient
           - If the patient later visited the referral_doctor, create edge
        
        Args:
            storage: Dictionary of records {visit_id: record}
            index_manager: IndexManager instance for efficient queries
        """
        self.storage = storage
        print("Building graph from referral patterns...")
        
        # Step 1: Add all visits as vertices
        for visit_id, record in storage.items():
            self.graph.insert_vertex(visit_id, record)
        
        print(f"Added {self.graph.num_vertices()} vertices")
        
        # Step 2: Build edges based on referrals
        edges_created = 0
        
        for visit_id, record in storage.items():
            patient_id = record['patient_id']
            current_doctor = record['doctor_id']
            referral_doctor = record['referral_doctor']
            
            # If this visit has a referral
            if referral_doctor and referral_doctor != current_doctor:
                # Find all visits by this patient
                patient_visits = index_manager.find_by_patient(patient_id)
                
                # Look for a visit where the patient saw the referral doctor
                for other_visit_id in patient_visits:
                    if other_visit_id == visit_id:
                        continue
                    
                    other_record = storage[other_visit_id]
                    
                    # If the other visit is with the referral doctor
                    if other_record['doctor_id'] == referral_doctor:
                        # Create edge: current_visit -> referred_visit
                        self.graph.insert_edge(
                            visit_id,
                            other_visit_id,
                            element={
                                'referral_doctor': referral_doctor,
                                'original_doctor': current_doctor,
                                'patient_id': patient_id
                            }
                        )
                        edges_created += 1
                        break  # Only create one edge per referral
        
        print(f"Created {edges_created} referral edges")
        print(f"Graph built successfully: {self.graph.num_vertices()} vertices, {self.graph.num_edges()} edges")
    
    def add_referral(self, from_visit_id, to_visit_id, referral_doctor=None):
        """Add a referral edge from one visit to another"""
        element = {'referral_doctor': referral_doctor} if referral_doctor else None
        return self.graph.insert_edge(from_visit_id, to_visit_id, element)
    
    def find_referral_chain(self, visit_id):
        """
        Find the chain of referrals leading to this visit.
        Returns list of visit_ids from original visit to current.
        Uses backward traversal through incoming edges.
        """
        vertex = self.graph.get_vertex(visit_id)
        if vertex is None:
            return []
        
        chain = []
        visited = set()  # Prevent infinite loops
        current = vertex
        
        # Follow predecessors backward (incoming edges)
        while current and current.visit_id not in visited:
            chain.insert(0, current.visit_id)
            visited.add(current.visit_id)
            
            incoming = self.graph.incoming_edges(current)
            if len(incoming) == 0:
                break
            
            # Take the first incoming edge (assume single referral source)
            predecessor = next(iter(incoming.keys()))
            current = predecessor
        
        return chain
    
    def find_all_referrals_from(self, visit_id):
        """
        Find all visits that were referred from this visit (direct and indirect).
        Uses BFS to find all reachable visits.
        """
        distances = self.graph.BFS(visit_id)
        return list(distances.keys())
    
    def find_patient_journey(self, patient_id):
        """
        Find the complete journey of a patient through different doctors.
        Returns list of (visit_id, doctor_id, diagnosis) tuples in chronological order.
        """
        if not self.storage:
            return []
        
        # Get all visits for this patient
        journey = []
        for visit_id, record in self.storage.items():
            if record['patient_id'] == patient_id:
                journey.append({
                    'visit_id': visit_id,
                    'doctor_id': record['doctor_id'],
                    'department': record['department'],
                    'diagnosis': record['diagnosis'],
                    'referral_doctor': record['referral_doctor']
                })
        
        return journey
    
    def find_doctor_referral_network(self, doctor_id, depth=1):
        """
        Find the network of doctors that this doctor refers to (or gets referrals from).
        Returns set of doctor_ids at given depth.
        
        Args:
            doctor_id: The doctor to analyze
            depth: How many referral steps to follow (1 = direct, 2 = indirect, etc.)
        """
        if not self.storage:
            return set()
        
        # Find all visits where this doctor made referrals
        referred_doctors = set()
        
        for visit_id, record in self.storage.items():
            if record['doctor_id'] == doctor_id and record['referral_doctor']:
                referred_doctors.add(record['referral_doctor'])
        
        # If depth > 1, recursively find referrals from referred doctors
        if depth > 1:
            extended_network = set(referred_doctors)
            for ref_doctor in referred_doctors:
                extended_network.update(
                    self.find_doctor_referral_network(ref_doctor, depth - 1)
                )
            return extended_network
        
        return referred_doctors
    
    def get_referral_statistics(self):
        """Get comprehensive statistics about referral patterns"""
        stats = {
            'total_visits': self.graph.num_vertices(),
            'total_referral_edges': self.graph.num_edges(),
            'visits_that_led_to_referrals': 0,
            'visits_that_were_referred': 0,
            'max_referrals_from_one_visit': 0,
            'max_incoming_referrals': 0,
            'isolated_visits': 0,
            'avg_referrals_per_visit': 0
        }
        
        total_out = 0
        
        for vertex in self.graph.get_vertices():
            out_deg = self.graph.out_degree(vertex)
            in_deg = self.graph.in_degree(vertex)
            
            if out_deg > 0:
                stats['visits_that_led_to_referrals'] += 1
                stats['max_referrals_from_one_visit'] = max(
                    stats['max_referrals_from_one_visit'], out_deg
                )
                total_out += out_deg
            
            if in_deg > 0:
                stats['visits_that_were_referred'] += 1
                stats['max_incoming_referrals'] = max(
                    stats['max_incoming_referrals'], in_deg
                )
            
            if out_deg == 0 and in_deg == 0:
                stats['isolated_visits'] += 1
        
        if stats['total_visits'] > 0:
            stats['avg_referrals_per_visit'] = round(
                total_out / stats['total_visits'], 2
            )
        
        return stats
    
    def find_longest_referral_chain(self):
        """
        Find the longest chain of referrals in the graph.
        Returns (length, chain) tuple where chain is list of visit_ids.
        """
        max_length = 0
        max_chain = []
        
        # Try BFS from each vertex to find longest path
        for start_vertex in self.graph.get_vertices():
            distances = self.graph.BFS(start_vertex.visit_id)
            
            for visit_id, dist in distances.items():
                if dist > max_length:
                    max_length = dist
                    # Reconstruct the path
                    path = self.graph.find_path(start_vertex.visit_id, visit_id)
                    max_chain = path
        
        return max_length, max_chain
    
    def detect_referral_cycles(self):
        """
        Detect if there are any cycles in referral patterns.
        Returns list of strongly connected components with size > 1.
        """
        sccs = self.graph.strongly_connected_components()
        cycles = [scc for scc in sccs if len(scc) > 1]
        return cycles
    
    def print_graph(self, limit=20):
        """Print the graph structure"""
        self.graph.print_graph(limit)
    
    def analyze_department_referrals(self):
        """
        Analyze which departments refer to which other departments.
        Returns dictionary: {from_dept: {to_dept: count}}
        """
        if not self.storage:
            return {}
        
        dept_referrals = {}
        
        for edge in self.graph.get_edges():
            from_visit, to_visit = edge.endpoints()
            from_dept = self.storage[from_visit.visit_id]['department']
            to_dept = self.storage[to_visit.visit_id]['department']
            
            if from_dept not in dept_referrals:
                dept_referrals[from_dept] = {}
            
            if to_dept not in dept_referrals[from_dept]:
                dept_referrals[from_dept][to_dept] = 0
            
            dept_referrals[from_dept][to_dept] += 1
        
        return dept_referrals


