    def find_circular_referrals(self):
        """Detect circular referral patterns (cycles in the graph)"""
        sccs = self.graph.strongly_connected_components()
        
        # Filter SCCs with more than 1 vertex (actual cycles)
        circular_patterns = []
        for component in sccs:
            if len(component) > 1:
                # Get patient info for this cycle
                patient_ids = set()
                visits = []
                for vid in component:
                    record = self.storage[vid]
                    patient_ids.add(record['patient_id'])
                    visits.append({
                        'visit_id': vid,
                        'patient_id': record['patient_id'],
                        'doctor_id': record['doctor_id'],
                        'department': record['department']
                    })
                
                circular_patterns.append({
                    'patients': list(patient_ids),
                    'visits': visits,
                    'cycle_length': len(component)
                })
        
        return circular_patterns


