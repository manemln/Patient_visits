    def get_graph_statistics(self):
        """Get overall graph statistics"""
        total_vertices = len(self.graph.vertices)
        total_edges = len(self.graph.get_edges())
        
        # Count connected components
        visited = set()
        components = 0
        
        for vertex in self.graph.vertices.values():
            if vertex.visit_id not in visited:
                components += 1
                # Simple BFS to mark component
                queue = [vertex]
                while queue:
                    v = queue.pop(0)
                    if v.visit_id in visited:
                        continue
                    visited.add(v.visit_id)
                    queue.extend(self.graph.outgoing_edges(v).keys())
                    queue.extend(self.graph.incoming_edges(v).keys())
        
        return {
            'total_vertices': total_vertices,
            'total_edges': total_edges,
            'connected_components': components,
            'average_degree': (2 * total_edges) / total_vertices if total_vertices > 0 else 0
        }
