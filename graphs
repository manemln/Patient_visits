    def find_department_transitions(self, patient_id):
        """Tracks how a patient moved between departments"""
        journey = self.find_patient_journey(patient_id)
        transitions = []
        
        for i in range(len(journey) - 1):
            curr = journey[i]
            next_visit = journey[i + 1]
            
            if curr['department'] != next_visit['department']:
                transitions.append({
                    'from_dept': curr['department'],
                    'to_dept': next_visit['department'],
                    'from_diagnosis': curr['diagnosis'],
                    'to_diagnosis': next_visit['diagnosis'],
                    'visit_ids': (curr['visit_id'], next_visit['visit_id'])
                })
        
        return transitions

