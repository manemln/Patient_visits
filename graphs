    def find_high_risk_paths(self, risk_threshold=0.7):
        """Find patient journeys with consistently high risk scores"""
        high_risk_journeys = {}
        
        # Group by patient
        for vid, record in self.storage.items():
            patient_id = record['patient_id']
            if patient_id not in high_risk_journeys:
                high_risk_journeys[patient_id] = []
            high_risk_journeys[patient_id].append({
                'visit_id': vid,
                'risk_score': record['risk_score'],
                'department': record['department'],
                'diagnosis': record['diagnosis']
            })
        
        # Filter patients with high average risk
        result = {}
        for patient_id, visits in high_risk_journeys.items():
            avg_risk = sum(v['risk_score'] for v in visits) / len(visits)
            if avg_risk >= risk_threshold:
                result[patient_id] = {
                    'average_risk': avg_risk,
                    'visit_count': len(visits),
                    'visits': sorted(visits, key=lambda x: x['visit_id'])
                }
        
        return result

