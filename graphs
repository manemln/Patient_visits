    def find_doctor_referral_network(self, doctor_id, depth=1):
        """Find doctors in referral network (both directions)"""
        network = {'refers_to': set(), 'referred_by': set()}
        
        for edge in self.graph.get_edges():
            edge_data = edge.element
            if edge_data:
                from_doc = edge_data.get('from_doctor')
                to_doc = edge_data.get('to_doctor')
                
                if from_doc == doctor_id:
                    network['refers_to'].add(to_doc)
                if to_doc == doctor_id:
                    network['referred_by'].add(from_doc)
        
        if depth > 1:
            extended_refers = set(network['refers_to'])
            extended_referred = set(network['referred_by'])
            
            for d in network['refers_to']:
                sub_network = self.find_doctor_referral_network(d, depth-1)
                extended_refers.update(sub_network['refers_to'])
            
            for d in network['referred_by']:
                sub_network = self.find_doctor_referral_network(d, depth-1)
                extended_referred.update(sub_network['referred_by'])
            
            network['refers_to'] = extended_refers
            network['referred_by'] = extended_referred
        
        return network



