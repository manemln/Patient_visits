    def strongly_connected_components(self):
        times = self.DFS()
        gt = self.transpose()

        for vertex in gt.vertices.values():
            vertex.color = "white"

        sccs = []

        def DFS_visit(u, component):
            u.color = "gray"
            component.append(u.visit_id)
            for v in gt.outgoing[u]:
                if v.color == "white":
                    DFS_visit(v, component)
            u.color = "black"

        sorted_vertices = sorted(times.items(), key=lambda x: x[1][1], reverse=True)
        for vid, _ in sorted_vertices:
            vertex = gt.vertices[vid]
            if vertex.color == "white":
                component = []
                DFS_visit(vertex, component)
                sccs.append(component)

        return sccs


class GraphManager:
    def __init__(self):
        self.graph = Graph(directed=True)
        self.storage = None

    def build_from_records(self, storage, index_manager):
        """Build graph with improved referral chain logic"""
        self.storage = storage
        
        # Insert all vertices
        for visit_id, record in storage.items():
            self.graph.insert_vertex(visit_id, record)

        # Build referral edges with temporal awareness
        patient_visits = {}  # patient_id -> list of (visit_id, record)
        
        # Group visits by patient
        for visit_id, record in storage.items():
            patient_id = record['patient_id']
            if patient_id not in patient_visits:
                patient_visits[patient_id] = []
            patient_visits[patient_id].append((visit_id, record))
        
        # Sort each patient's visits by visit_id (proxy for time)
        for patient_id, visits in patient_visits.items():
            visits.sort(key=lambda x: x[0])  # Sort by visit_id
            
            # Create edges between consecutive visits
            for i in range(len(visits) - 1):
                curr_vid, curr_rec = visits[i]
                next_vid, next_rec = visits[i + 1]
                
                # Edge from current visit to next visit
                self.graph.insert_edge(curr_vid, next_vid, {
                    "patient_id": patient_id,
                    "from_doctor": curr_rec['doctor_id'],
                    "to_doctor": next_rec['doctor_id'],
                    "from_department": curr_rec['department'],
                    "to_department": next_rec['department'],
                    "is_referral": curr_rec.get('referral_doctor') == next_rec['doctor_id']
                })

    def find_patient_journey(self, patient_id):
        """Get complete patient journey with visit details"""
        journey = []
        for vid, record in self.storage.items():
            if record['patient_id'] == patient_id:
                journey.append({
                    'visit_id': vid,
                    'doctor_id': record['doctor_id'],
                    'department': record['department'],
                    'diagnosis': record['diagnosis'],
                    'treatment_cost': record['treatment_cost'],
                    'risk_score': record['risk_score'],
                    'outcome_score': record['outcome_score'],
                    'referral_doctor': record.get('referral_doctor')
                })
        return sorted(journey, key=lambda x: x['visit_id'])


