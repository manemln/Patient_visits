class GraphManager:
    """
    Integrates with IndexManager to build graph from visit records
    GRAPH BUILDING STRATEGY:
    - Vertices: Each visit_id is a vertex
    - Edges: Created based on doctor referrals between patients
    
    Logic: When patient P sees doctor D1 and gets referred to doctor D2,
    we find the visit where P sees D2 and create an edge from the original visit
    to the referred visit.
    """

    def __init__(self):
        self.graph = Graph(directed=True)
        self.storage = None
    
    def build_from_records(self, storage, index_manager):
        """
        Build graph from medical records using referral_doctor field.
        
        Strategy:
        1. Add all visits as vertices
        2. For each visit with a referral_doctor:
           - Find other visits by the same patient
           - If the patient later visited the referral_doctor, create edge
        
        Args:
            storage: Dictionary of records {visit_id: record}
            index_manager: IndexManager instance for efficient queries
        """
        self.storage = storage
        print("Building graph from referral patterns...")
        
        # Step 1: Add all visits as vertices
        for visit_id, record in storage.items():
            self.graph.insert_vertex(visit_id, record)
        
        print(f"Added {self.graph.num_vertices()} vertices")
        
        # Step 2: Build edges based on referrals
        edges_created = 0
        
        for visit_id, record in storage.items():
            patient_id = record['patient_id']
            current_doctor = record['doctor_id']
            referral_doctor = record['referral_doctor']
            
            # If this visit has a referral
            if referral_doctor and referral_doctor != current_doctor:
                # Find all visits by this patient
                patient_visits = index_manager.find_by_patient(patient_id)
                
                # Look for a visit where the patient saw the referral doctor
                for other_visit_id in patient_visits:
                    if other_visit_id == visit_id:
                        continue
                    
                    other_record = storage[other_visit_id]
                    
                    # If the other visit is with the referral doctor
                    if other_record['doctor_id'] == referral_doctor:
                        # Create edge: current_visit -> referred_visit
                        self.graph.insert_edge(
                            visit_id,
                            other_visit_id,
                            element={
                                'referral_doctor': referral_doctor,
                                'original_doctor': current_doctor,
                                'patient_id': patient_id
                            }
                        )
                        edges_created += 1
                        break  # Only create one edge per referral
        
        print(f"Created {edges_created} referral edges")
        print(f"Graph built successfully: {self.graph.num_vertices()} vertices, {self.graph.num_edges()} edges")
    
    def add_referral(self, from_visit_id, to_visit_id, referral_doctor=None):
        """Add a referral edge from one visit to another"""
        element = {'referral_doctor': referral_doctor} if referral_doctor else None
        return self.graph.insert_edge(from_visit_id, to_visit_id, element)
    
    def find_referral_chain(self, visit_id):
        """
        Find the chain of referrals leading to this visit.
        Returns list of visit_ids from original visit to current.
        Uses backward traversal through incoming edges.
        """
        vertex = self.graph.get_vertex(visit_id)
        if vertex is None:
            return []
        
        chain = []
        visited = set()  # Prevent infinite loops
        current = vertex
        
        # Follow predecessors backward (incoming edges)
        while current and current.visit_id not in visited:
            chain.insert(0, current.visit_id)
            visited.add(current.visit_id)
            
            incoming = self.graph.incoming_edges(current)
            if len(incoming) == 0:
                break
            
            # Take the first incoming edge (assume single referral source)
            predecessor = next(iter(incoming.keys()))
            current = predecessor
        
        return chain
    
    def find_all_referrals_from(self, visit_id):
        """
        Find all visits that were referred from this visit (direct and indirect).
        Uses BFS to find all reachable visits.
        """
        distances = self.graph.BFS(visit_id)
        return list(distances.keys())
    
    def find_patient_journey(self, patient_id):
        """
        Find the complete journey of a patient through different doctors.
        Returns list of (visit_id, doctor_id, diagnosis) tuples in chronological order.
        """
        if not self.storage:
            return []
        
        # Get all visits for this patient
        journey = []
        for visit_id, record in self.storage.items():
            if record['patient_id'] == patient_id:
                journey.append({
                    'visit_id': visit_id,
                    'doctor_id': record['doctor_id'],
                    'department': record['department'],
                    'diagnosis': record['diagnosis'],
                    'referral_doctor': record['referral_doctor']
                })
        
        return journey
    
    def find_doctor_referral_network(self, doctor_id, depth=1):
        """
        Find the network of doctors that this doctor refers to (or gets referrals from).
        Returns set of doctor_ids at given depth.
        
        Args:
            doctor_id: The doctor to analyze
            depth: How many referral steps to follow (1 = direct, 2 = indirect, etc.)
        """
        if not self.storage:
            return set()
        
        # Find all visits where this doctor made referrals
        referred_doctors = set()
        
        for visit_id, record in self.storage.items():
            if record['doctor_id'] == doctor_id and record['referral_doctor']:
                referred_doctors.add(record['referral_doctor'])
        
        # If depth > 1, recursively find referrals from referred doctors
        if depth > 1:
            extended_network = set(referred_doctors)
            for ref_doctor in referred_doctors:
                extended_network.update(
                    self.find_doctor_referral_network(ref_doctor, depth - 1)
                )
            return extended_network
        
        return referred_doctors
    
    def get_referral_statistics(self):
        """Get comprehensive statistics about referral patterns"""
        stats = {
            'total_visits': self.graph.num_vertices(),
            'total_referral_edges': self.graph.num_edges(),
            'visits_that_led_to_referrals': 0,
            'visits_that_were_referred': 0,
            'max_referrals_from_one_visit': 0,
            'max_incoming_referrals': 0,
            'isolated_visits': 0,
            'avg_referrals_per_visit': 0
        }
        
        total_out = 0
        
        for vertex in self.graph.get_vertices():
            out_deg = self.graph.out_degree(vertex)
            in_deg = self.graph.in_degree(vertex)
            
            if out_deg > 0:
                stats['visits_that_led_to_referrals'] += 1
                stats['max_referrals_from_one_visit'] = max(
                    stats['max_referrals_from_one_visit'], out_deg
                )
                total_out += out_deg
            
            if in_deg > 0:
                stats['visits_that_were_referred'] += 1
                stats['max_incoming_referrals'] = max(
                    stats['max_incoming_referrals'], in_deg
                )
            
            if out_deg == 0 and in_deg == 0:
                stats['isolated_visits'] += 1
        
        if stats['total_visits'] > 0:
            stats['avg_referrals_per_visit'] = round(
                total_out / stats['total_visits'], 2
            )
        
        return stats
    
    def find_longest_referral_chain(self):
        """
        Find the longest chain of referrals in the graph.
        Returns (length, chain) tuple where chain is list of visit_ids.
        """
        max_length = 0
        max_chain = []
        
        # Try BFS from each vertex to find longest path
        for start_vertex in self.graph.get_vertices():
            distances = self.graph.BFS(start_vertex.visit_id)
            
            for visit_id, dist in distances.items():
                if dist > max_length:
                    max_length = dist
                    # Reconstruct the path
                    path = self.graph.find_path(start_vertex.visit_id, visit_id)
                    max_chain = path
        
        return max_length, max_chain
    
    def detect_referral_cycles(self):
        """
        Detect if there are any cycles in referral patterns.
        Returns list of strongly connected components with size > 1.
        """
        sccs = self.graph.strongly_connected_components()
        cycles = [scc for scc in sccs if len(scc) > 1]
        return cycles
    
    def print_graph(self, limit=20):
        """Print the graph structure"""
        self.graph.print_graph(limit)
    
    def analyze_department_referrals(self):
        """
        Analyze which departments refer to which other departments.
        Returns dictionary: {from_dept: {to_dept: count}}
        """
        if not self.storage:
            return {}
        
        dept_referrals = {}
        
        for edge in self.graph.get_edges():
            from_visit, to_visit = edge.endpoints()
            from_dept = self.storage[from_visit.visit_id]['department']
            to_dept = self.storage[to_visit.visit_id]['department']
            
            if from_dept not in dept_referrals:
                dept_referrals[from_dept] = {}
            
            if to_dept not in dept_referrals[from_dept]:
                dept_referrals[from_dept][to_dept] = 0
            
            dept_referrals[from_dept][to_dept] += 1
        
        return dept_referrals


