import csv

#Storing csv in list where every value is a dictionary
class DataStorage:
    def __init__(self, path):
        self.path = path
        self.records = {}    #After encountaring a problem we changed List of Dict to Dict of dicts

    def load_data(self):
        with open(self.path, "r") as f:
            reader = csv.DictReader(f)
            for row in reader:
                row["visit_id"] = int(row["visit_id"])
                row["patient_id"] = int(row["patient_id"])
                row["doctor_id"] = int(row["doctor_id"])
                row["treatment_cost"] = float(row["treatment_cost"])
                row["number_of_visits"] = int(row["number_of_visits"])
                row["risk_score"] = float(row["risk_score"])
                row["outcome_score"] = float(row["outcome_score"])

                self.records[row["visit_id"]] = row

        print("Loaded", len(self.records), "records.")

    def get_all(self):
        return self.records


#AVL TREE on stored dataset
class AVLNode:
    def __init__(self, key, record_ids):
        self.key = key
        self.record_ids = record_ids
        self.height = 1
        self.left = None
        self.right = None


class AVLTree:
    def __init__(self):
        self.root = None

    #helpers to get height, change height, and detect balance between siblings
    def get_height(self, node):
        return node.height if node else 0

    def get_balance(self, node):
        return self.get_height(node.left) - self.get_height(node.right)

    def update_height(self, node):
        node.height = 1 + max(self.get_height(node.left),
                              self.get_height(node.right))

    #rotations to balance the tree after adding or removing
    def rotate_left(self, x):
        y = x.right   #we keep T2, put x as y's parent, then put T2 as left child of y
        T2 = y.left  

        y.left = x    
        x.right = T2

        self.update_height(x)
        self.update_height(y)

        return y

    def rotate_right(self, x):
        y = x.left       #the same for right
        T3 = y.right

        y.right = x
        x.left = T3

        self.update_height(x)
        self.update_height(y)

        return y

    def insert(self, node, key, record_id):
        if not node:
            return AVLNode(key, [record_id])

        if key < node.key:
            node.left = self.insert(node.left, key, record_id)
        elif key > node.key:
            node.right = self.insert(node.right, key, record_id)
        else:
            #the logic is the same as ord. insert
            #if the node is not in the tree create a node with the given id
            #if the key is there, add the id to the node's values list
            node.record_ids.append(record_id)
            return node

        self.update_height(node)
        balance = self.get_balance(node)

        #This part considers minus cases, as the balance factor
        #does not compute the absolute value

        #Single left rotation, 3 nodes: left child of left child
        if balance > 1 and key < node.left.key:
            return self.rotate_right(node)

        #Single rotation for right
        if balance < -1 and key > node.right.key:
            return self.rotate_left(node)

        #Double rotation 3 nodes: left child then right child
        if balance > 1 and key > node.left.key:
            node.left = self.rotate_left(node.left)
            return self.rotate_right(node)

        #Double rotation 3 nodes: right child then left child
        if balance < -1 and key < node.right.key:
            node.right = self.rotate_right(node.right)
            return self.rotate_left(node)

        return node

    #The same method for user usage, as the user need to input the information he/she have
    def add(self, key, record_id):
        self.root = self.insert(self.root, key, record_id)

    def search(self, key):
        node = self.root
        while node:
            if key < node.key:
                node = node.left
            elif key > node.key:
                node = node.right
            else:
                return list(node.record_ids) 
        return []

    def delete(self, node, key, record_id):
        if not node:    #if no such node exist, no need to delete
            return None

        if key < node.key:
            node.left = self.delete(node.left, key, record_id)
        elif key > node.key:
            node.right = self.delete(node.right, key, record_id)
        else:
            #if the key matches, remove id from values' list
            if record_id in node.record_ids:
                node.record_ids.remove(record_id)

            #if after deletion the list is not empty, we keep the node
            if len(node.record_ids) > 0:
                return node

            #otherwise, the same node deletion logic, copy the successor, delete the sentinel
            if not node.left:
                return node.right
            if not node.right:
                return node.left

            successor = node.right
            while successor.left:
                successor = successor.left
            node.key = successor.key
            node.record_ids = successor.record_ids
            node.right = self.delete(node.right, successor.key, successor.record_ids[0])

        self.update_height(node)
        balance = self.get_balance(node)

        #rebalance part, the same way 
        if balance > 1 and self.get_balance(node.left) >= 0:
            return self.rotate_right(node)
        
        if balance > 1 and self.get_balance(node.left) < 0:
            node.left = self.rotate_left(node.left)
            return self.rotate_right(node)
        
        if balance < -1 and self.get_balance(node.right) <= 0:
            return self.rotate_left(node)
        
        if balance < -1 and self.get_balance(node.right) > 0:
            node.right = self.rotate_right(node.right)
            return self.rotate_left(node)

        return node

    #Delete for user
    def remove(self, key, record_id):
        self.root = self.delete(self.root, key, record_id)


#CLASS INDEX MANAGER for building AVLs and using them
class IndexManager:
    def __init__(self):
        self.by_patient = AVLTree()
        self.by_doctor = AVLTree()
        self.by_cost = AVLTree()
        self.by_visit = AVLTree()  #To fix the problem mentioned (row ...) we added this AVL
        #NEEDS TO BE CHANGED       #AVL will keep more space, but will let us to quickly see whether
                                   #we have the visit_id we wanted to insert
        self.storage = {}

    def build(self, storage):
        self.storage = storage
        for visit_id, record in storage.items():   #the record is a dictionary of a single row
                                 #so we go over the dictionaries (rows) and take the key (col names)
                                 #then for the values, add every new visit id to the values' list
            self.by_patient.add(record["patient_id"], visit_id)
            self.by_doctor.add(record["doctor_id"], visit_id)
            self.by_cost.add(record["treatment_cost"], visit_id)
            self.by_visit.add(visit_id, visit_id)

    #ways to use AVLs
    def find_by_patient(self, patient_id):
        return self.by_patient.search(patient_id)

    def find_by_doctor(self, doctor_id):
        return self.by_doctor.search(doctor_id)

    def find_by_cost(self, cost):
        return self.by_cost.search(cost)
    
    def find_by_visit(self, visit_id):
        return self.by_visit.search(visit_id)
    
    def find_by_cost_range(self, low, high):
        return self.range_query(self.by_cost, low, high)

    #Insering and deleting from AVLs, as after adding or removing
    #a visit in dataset, we should add of remove it from AVLs as well
    def add_record(self, record):
        #Checking if we have the visit_id
        if len(self.by_visit.search(record["visit_id"])) > 0:
            print(f"We detected duplicate visit_id {record["visit_id"]}. Record rejected.")
            return

        #from stored data
        self.storage[visit_id] = record   #O(1)

        #During insersion, we have to fix this problem  of adding dublicate visit_ids
        #because we can not have two equal visit_ids with different information
        #Now from AVLs
        self.by_patient.add(record["patient_id"], record["visit_id"])
        self.by_doctor.add(record["doctor_id"], record["visit_id"])
        self.by_cost.add(record["treatment_cost"], record["visit_id"])
        self.by_visit.add(record["visit_id"], record["visit_id"])

        print(f"Added visit {visit_id}")
        return record


    def delete_record(self, visit_id):
        record = self.storage.pop(visit_id, None)
        if not record:
            return record

        #Removing from all AVL trees too
        self.by_patient.remove(record["patient_id"], visit_id)
        self.by_doctor.remove(record["doctor_id"], visit_id)
        self.by_cost.remove(record["treatment_cost"], visit_id)
        self.by_visit.remove(visit_id, visit_id)

        print(f"Deleted visit {visit_id}")
        return record

    def range_query(self, avl, low, high):
        """Return list of visit_ids whose AVL key is between low and high."""
        result = []

        def inorder(node):
            if not node:
                return
        
            #To go left till meeting the low
            if node.key >= low:
                inorder(node.left)

            #To take each visit in values' list and append to record
            if low <= node.key <= high:
                for i in node.record_ids:
                    result.append(i)

            #To go right till meeting the high
            if node.key <= high:
                inorder(node.right)

        inorder(avl.root)
        return result

    def modify_record(self, visit_id, field, new_value):
        record = self.storage.get(visit_id)
        if not record:
            print(f"Visit {visit_id} not found.")
            return False
        old_value = record[field]
        if old_value == new_value:
            return record    #Even when we dont change, we show the row

        #Checking whether the field we want to change is an AVL, if yes,
        #we remove the visit id from values' list, which had the unchanged key, then insert again
        #this time using the new key
        if field == "patient_id":
            self.by_patient.remove(old_value, visit_id)
            self.by_patient.add(new_value, visit_id)
        elif field == "doctor_id":
            self.by_doctor.remove(old_value, visit_id)
            self.by_doctor.add(new_value, visit_id)
        elif field == "treatment_cost":
            self.by_cost.remove(old_value, visit_id)
            self.by_cost.add(new_value, visit_id) 

        #then we update the record in our storage
        record[field] = new_value

        print(f"Modified visit {visit_id}: {field} changed from {old_value} to {new_value}")
        return record



#GRAPH
class Vertex:
    #vertex in the graph (a visit_id)
    def __init__(self, visit_id, element=None):
        self.visit_id = visit_id 
        self.element = element     # Can store additional data (the full record)
        self.color = "white"       # For BFS/DFS: white, gray, black
        self.distance = float('inf')  
        self.predecessor = None    # For BFS/DFS: parent in traversal tree
        self.discovery_time = 0    # For DFS: when vertex was discovered
        self.finish_time = 0       # For DFS: when vertex processing finished
    
    def get_element(self):
        return self.element
    
    def __str__(self):
        return f"Vertex(visit_id={self.visit_id})"

class Edge:
    #edge in the graph (referral relationship)
    def __init__(self, origin, destination, element=None):
        self.origin = origin         
        self.destination = destination 
        self.element = element         #Can store referral info(doctor_id,...)
    
    def endpoints(self):
        #gives tuple of (origin, destination)vertices
        return (self.origin, self.destination)
    
    def opposite(self, vertex):
        #returns the vertex opposite to the given vertex on this edge
        if vertex == self.origin:
            return self.destination
        elif vertex == self.destination:
            return self.origin
        else:
            raise ValueError("Vertex not incident to this edge")
    
    def get_element(self):
        return self.element
    
    def __str__(self):
        return f"Edge({self.origin.visit_id} -> {self.destination.visit_id})"

class Graph:
    #Adjacency Map representation of a directed graph
    def __init__(self, directed=True):
        self.directed = directed
        self.vertices = {}  # maps visit_id to Vertex object, {1:Vertex(1),...}
        #Adjacency map = vertex -> {opposite_vertex: Edge} 
        self.outgoing = {} #{
                                Vertex(1):{
                                            Vertex(15): Edge(1→15), ...
                                          }
                            #}
        self.incoming = {} #like outgoing
    
    #basic graph operations
    def num_vertices(self):
        return len(self.vertices)
    
    def num_edges(self):
        total = sum(len(edges) for edges in self.outgoing.values())
        return total
    
    def get_vertices(self):
        return self.vertices.values()
        #getting all vertices
    
    def get_edges(self):
        edges = []
        for vertex_edges in self.outgoing.values():
            edges.extend(vertex_edges.values())
        return edges
        #won't have duplicates as we use directed graph in case of undirected we would use set to avoid duplics

    def get_vertex(self, visit_id):
        return self.vertices.get(visit_id)
        #getting 1 vertex by visit_id
    
    def get_edge(self, u, v):
        #returns edge from vertex u to v, or None if it doesn't exist
        if isinstance(u, int):
            u = self.vertices.get(u)
        if isinstance(v, int):
            v = self.vertices.get(v)
        
        if u is None or v is None:
            return None
        
        return self.outgoing.get(u, {}).get(v) 
#if u exists returns its values{vertex-edge couples},get the value of vertex v inside it which is the correspoding edge 
    
    def degree(self, v, outgoing=True):
        #return number of outgoing edges from v
        if isinstance(v, int):
            v = self.vertices.get(v)
        
        adj_map = self.outgoing if outgoing else self.incoming
        return len(adj_map.get(v, {}))
    
    def out_degree(self, v):
        return self.degree(v, True)
    
    def in_degree(self, v):
        return self.degree(v, False)
    
    def incident_edges(self, v, outgoing=True):
        #return all outgoing (or incoming) edges from vertex v
        #returns dictionary {opposite_vertex: edge}
        if isinstance(v, int):
            v = self.vertices.get(v)
        
        adj_map = self.outgoing if outgoing else self.incoming
        return adj_map.get(v, {})
    
    def outgoing_edges(self, v):
        return self.incident_edges(v, True)
    
    def incoming_edges(self, v):
        return self.incident_edges(v, False)
    
    #modification operations
    def insert_vertex(self, visit_id, element=None):
        #creates and returns a new Vertex storing visit_id
        if visit_id in self.vertices:
            return self.vertices[visit_id]
        
        v = Vertex(visit_id, element)
        self.vertices[visit_id] = v
        self.outgoing[v] = {}
        self.incoming[v] = {}
        return v
    
    def insert_edge(self, u, v, element=None):
        #creates and returns a new Edge from vertex u to vertex v

        # Convert visit_ids to Vertex objects if needed
        if isinstance(u, int):
            if u not in self.vertices:
                u = self.insert_vertex(u)
            else:
                u = self.vertices[u]
        
        if isinstance(v, int):
            if v not in self.vertices:
                v = self.insert_vertex(v)
            else:
                v = self.vertices[v]
        
        # Check if edge already exists
        if v in self.outgoing[u]:
            return self.outgoing[u][v]
        
        #Creating edge
        e = Edge(u, v, element)
        self.outgoing[u][v] = e
        self.incoming[v][u] = e
        
        return e
    
    def remove_vertex(self, v):
        #remove vertex v and all its incident edges
        if isinstance(v, int):
            v = self.vertices.get(v)
        
        if v is None:
            return
        
        # Remove all outgoing edges
        for dest in list(self.outgoing[v].keys()):#{dest:edge}
            del self.incoming[dest][v]#remove value of dest which is the edge connecting origin to dest
        del self.outgoing[v]
        
        # Remove all incoming edges
        for origin in list(self.incoming[v].keys()):
            del self.outgoing[origin][v]
        del self.incoming[v]
        
        # Remove vertex itself
        del self.vertices[v.visit_id]
    
    def remove_edge(self, e):
        u, v = e.endpoints() #origin goes to destination
        
        if v in self.outgoing.get(u, {}): # takes origins' values {dest:edge,dest:edge,...}
            del self.outgoing[u][v] # remove dest:edge couple
        
        if u in self.incoming.get(v, {}):
            del self.incoming[v][u]
    
    #traversals
    
    def BFS(self, start_visit_id):
        #returns dictionary: {visit_id: distance_from_start}
        #sets vertex.color, vertex.distance, vertex.predecessor

        for vertex in self.vertices.values():
            vertex.color = "white"
            vertex.distance = float('inf')
            vertex.predecessor = None
        
        #start vertex
        start = self.vertices.get(start_visit_id)
        if start is None:
            print(f"Start vertex {start_visit_id} not found")
            return {}
        
        #Initialize start vertex
        start.color = "gray"
        start.distance = 0
        start.predecessor = None
        
        #list as a queue (append to end, pop from beginning)
        queue = [start]
        distances = {start.visit_id: 0}
        
        while queue:
            u = queue.pop(0)  # Dequeue from front
            
            # Explore all adjacent vertices
            for v, edge in self.outgoing[u].items():
                if v.color == "white": 
                    v.color = "gray"
                    v.distance = u.distance + 1
                    v.predecessor = u
                    distances[v.visit_id] = v.distance
                    queue.append(v)
            
            u.color = "black"  # Finished processing
        
        return distances
    
    def DFS(self):
        #returns dictionary: {visit_id: (discovery_time, finish_time)}
       #sets vertex.color, vertex.discovery_time, vertex.finish_time, vertex.predecessor
    
        for vertex in self.vertices.values():
            vertex.color = "white"
            vertex.predecessor = None
            vertex.discovery_time = 0
            vertex.finish_time = 0
        
        time = [0]  # Use list to make it mutable in nested function
        times = {}
        
        def DFS_visit(u):
            time[0] += 1
            u.discovery_time = time[0]
            u.color = "gray"
            
            # Explore all adjacent vertices
            for v, edge in self.outgoing[u].items():
                if v.color == "white":
                    v.predecessor = u
                    DFS_visit(v)
            
            u.color = "black"
            time[0] += 1
            u.finish_time = time[0]
            times[u.visit_id] = (u.discovery_time, u.finish_time)
        
        # Visit all vertices (to handle disconnected components)
        for vertex in self.vertices.values():
            if vertex.color == "white":
                DFS_visit(vertex)
        
        return times
    
    def DFS_from_vertex(self, start_visit_id):
        #returns list of visit_ids in DFS order
        start = self.vertices.get(start_visit_id)
        if start is None:
            print(f"Start vertex {start_visit_id} not found")
            return []
        
        # Initialize
        for vertex in self.vertices.values():
            vertex.color = "white"
        
        dfs_order = []
        
        def DFS_visit(u):
            u.color = "gray"
            dfs_order.append(u.visit_id)
            
            for v, edge in self.outgoing[u].items():
                if v.color == "white":
                    DFS_visit(v)
            
            u.color = "black"
        
        DFS_visit(start)
        return dfs_order
    
    def find_path(self, start_visit_id, end_visit_id):
        #finding the shortest path from start to end using BFS
        #returns list of visit_ids representing the path, or empty list if no path exists
     
        #BFS from start
        self.BFS(start_visit_id)
        
        end = self.vertices.get(end_visit_id)
        if end is None or end.distance == float('inf'):
            return []  # No path exists
        
        #path by following predecessors backward
        path = []
        current = end
        while current is not None:
            path.append(current.visit_id)
            current = current.predecessor
        
        path.reverse()  #get start to end order
        return path
    
    def is_connected(self):
        #checking if graph is connected
        #returns True if all vertices are reachable from any starting vertex
        
        if len(self.vertices) == 0:
            return True
        
        #any vertex
        start = next(iter(self.vertices.values()))
        
        # Run DFS
        visited = set()
        
        def DFS_visit(u):
            visited.add(u.visit_id)
            for v in self.outgoing[u].keys():
                if v.visit_id not in visited:
                    DFS_visit(v)
        
        DFS_visit(start)
        return len(visited) == len(self.vertices)
    
    def topological_sort(self):
        #topological sort on DAG
        #returns list of visit_ids in topological order, or None if graph has cycles
        
        # Run DFS to compute finish times
        times = self.DFS()
        
        # Sort vertices by decreasing finish time
        sorted_vertices = sorted(times.items(), key=lambda x: x[1][1], reverse=True) #((vertex,(1,8)),(vertex2,())
        return [visit_id for visit_id, _ in sorted_vertices]






 #---------------------------------------------------------------------------------------------
    def transpose(self):
        #used for finding strongly connected components

        gt = Graph(directed=self.directed)
        
        # Add all vertices
        for visit_id, vertex in self.vertices.items():
            gt.insert_vertex(visit_id, vertex.element)
        
        # Add all edges in reverse direction
        for edge in self.get_edges():
            u, v = edge.endpoints()
            gt.insert_edge(v.visit_id, u.visit_id, edge.element)
        
        return gt
    
    def strongly_connected_components(self):
       
        #find strongly connected components using s
        #returns list of lists, where each inner list is a strongly connected component

        if not self.directed:
            print("SCC only applies to directed graphs")
            return None
        
        # Step 1: Run DFS on original graph to get finish times
        times = self.DFS()
        
        # Step 2: Create transpose graph
        gt = self.transpose()
        
        # Step 3: Run DFS on transpose in decreasing finish time order
        # Initialize
        for vertex in gt.vertices.values():
            vertex.color = "white"
        
        sccs = []
        
        def DFS_visit(u, component):
            u.color = "gray"
            component.append(u.visit_id)
            
            for v in gt.outgoing[u].keys():
                if v.color == "white":
                    DFS_visit(v, component)
            
            u.color = "black"
        
        # Visit vertices in decreasing finish time order
        sorted_vertices = sorted(times.items(), key=lambda x: x[1][1], reverse=True)
        
        for visit_id, _ in sorted_vertices:
            vertex = gt.vertices[visit_id]
            if vertex.color == "white":
                component = []
                DFS_visit(vertex, component)
                sccs.append(component)
        
        return sccs
    
  
