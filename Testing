import csv
import os

def test_graph_all_methods():
    """Comprehensive test of ALL Graph class methods"""
    
    print("GRAPH CLASS - COMPREHENSIVE TEST\n")
    
    # Create a directed graph
    g = Graph(directed=True)
    print("✓ Graph(directed=True): Created directed graph\n")
    
    # ========== Test Vertex Operations ==========
    print("TEST 1: Vertex Operations")
    
    # insert_vertex
    v1 = g.insert_vertex(1, {"name": "Visit 1"})
    v2 = g.insert_vertex(2, {"name": "Visit 2"})
    v3 = g.insert_vertex(3, {"name": "Visit 3"})
    v4 = g.insert_vertex(4, {"name": "Visit 4"})
    v5 = g.insert_vertex(5, {"name": "Visit 5"})
    print(f"✓ insert_vertex(): Added 5 vertices")
    
    # Try inserting duplicate (should return existing vertex)
    v1_dup = g.insert_vertex(1, {"name": "Duplicate"})
    print(f"✓ insert_vertex(duplicate): Returns existing vertex: {v1 == v1_dup}")
    
    # get_vertex
    vertex = g.get_vertex(3)
    print(f"✓ get_vertex(3): {vertex}")
    
    # get_vertices
    all_vertices = list(g.get_vertices())
    print(f"✓ get_vertices(): Retrieved {len(all_vertices)} vertices")
    
    # num_vertices
    print(f"✓ num_vertices(): {g.num_vertices()}\n")
    
    # ========== Test Edge Operations ==========
    print("TEST 2: Edge Operations")
    
    # insert_edge
    e1 = g.insert_edge(1, 2, {"referral": "doctor_A"})
    e2 = g.insert_edge(2, 3, {"referral": "doctor_B"})
    e3 = g.insert_edge(1, 3, {"referral": "doctor_C"})
    e4 = g.insert_edge(3, 4, {"referral": "doctor_D"})
    e5 = g.insert_edge(4, 5, {"referral": "doctor_E"})
    e6 = g.insert_edge(2, 5, {"referral": "doctor_F"})
    print(f"✓ insert_edge(): Added 6 edges")
    
    # Try inserting duplicate edge
    e1_dup = g.insert_edge(1, 2, {"referral": "duplicate"})
    print(f"✓ insert_edge(duplicate): Returns existing edge: {e1 == e1_dup}")
    
    # insert_edge with visit_ids (auto-creates vertices)
    e7 = g.insert_edge(6, 7, {"referral": "doctor_G"})
    print(f"✓ insert_edge(6, 7): Auto-created vertices, now {g.num_vertices()} vertices")
    
    # get_edge
    edge = g.get_edge(1, 2)
    print(f"✓ get_edge(1, 2): {edge}")
    
    # get_edge with non-existent edge
    edge_none = g.get_edge(1, 5)
    print(f"✓ get_edge(1, 5): {edge_none} (None as expected)")
    
    # get_edges
    all_edges = g.get_edges()
    print(f"✓ get_edges(): Retrieved {len(all_edges)} edges")
    
    # num_edges
    print(f"✓ num_edges(): {g.num_edges()}\n")
    
    # ========== Test Edge Class Methods ==========
    print("TEST 3: Edge Class Methods")
    
    # endpoints
    origin, dest = e1.endpoints()
    print(f"✓ edge.endpoints(): ({origin.visit_id}, {dest.visit_id})")
    
    # opposite
    opp = e1.opposite(v1)
    print(f"✓ edge.opposite(v1): {opp.visit_id}")
    
    # get_element
    elem = e1.get_element()
    print(f"✓ edge.get_element(): {elem}\n")
    
    # ========== Test Degree Methods ==========
    print("TEST 4: Degree Methods")
    
    # degree (outgoing)
    deg_out = g.degree(v1, outgoing=True)
    print(f"✓ degree(v1, outgoing=True): {deg_out}")
    
    # degree (incoming)
    deg_in = g.degree(v3, outgoing=False)
    print(f"✓ degree(v3, outgoing=False): {deg_in}")
    
    # out_degree
    out_deg = g.out_degree(v2)
    print(f"✓ out_degree(v2): {out_deg}")
    
    # in_degree
    in_deg = g.in_degree(v3)
    print(f"✓ in_degree(v3): {in_deg}")
    
    # Test with visit_id instead of vertex object
    out_deg_id = g.out_degree(1)
    print(f"✓ out_degree(1): {out_deg_id}\n")
    
    # ========== Test Incident Edges ==========
    print("TEST 5: Incident Edges Methods")
    
    # incident_edges (outgoing)
    out_edges = g.incident_edges(v1, outgoing=True)
    print(f"✓ incident_edges(v1, outgoing=True): {len(out_edges)} edges")
    
    # incident_edges (incoming)
    in_edges = g.incident_edges(v3, outgoing=False)
    print(f"✓ incident_edges(v3, outgoing=False): {len(in_edges)} edges")
    
    # outgoing_edges
    outgoing = g.outgoing_edges(v2)
    print(f"✓ outgoing_edges(v2): {len(outgoing)} edges")
    for dest_v, edge in outgoing.items():
        print(f"  -> {dest_v.visit_id}")
    
    # incoming_edges
    incoming = g.incoming_edges(v3)
    print(f"✓ incoming_edges(v3): {len(incoming)} edges")
    for origin_v, edge in incoming.items():
        print(f"  <- {origin_v.visit_id}\n")
    
    # ========== Test BFS ==========
    print("TEST 6: BFS (Breadth-First Search)")
    
    distances = g.BFS(1)
    print(f"✓ BFS(1): Found distances to {len(distances)} vertices")
    for visit_id, dist in sorted(distances.items()):
        print(f"  visit_id {visit_id}: distance = {dist}")
    
    # Check vertex properties set by BFS
    print(f"✓ After BFS, vertex colors/distances set:")
    print(f"  v1.color: {v1.color}, v1.distance: {v1.distance}")
    print(f"  v3.color: {v3.color}, v3.distance: {v3.distance}, v3.predecessor: {v3.predecessor.visit_id if v3.predecessor else None}\n")
    
    # ========== Test DFS ==========
    print("TEST 7: DFS (Depth-First Search)")
    
    times = g.DFS()
    print(f"✓ DFS(): Found times for {len(times)} vertices")
    for visit_id, (disc, fin) in sorted(times.items()):
        print(f"  visit_id {visit_id}: discovery={disc}, finish={fin}")
    
    # Check vertex properties
    print(f"✓ After DFS, vertex times set:")
    print(f"  v1: discovery={v1.discovery_time}, finish={v1.finish_time}\n")
    
    # ========== Test DFS from Vertex ==========
    print("TEST 8: DFS from Specific Vertex")
    
    dfs_order = g.DFS_from_vertex(1)
    print(f"✓ DFS_from_vertex(1): {dfs_order}")
    
    dfs_order2 = g.DFS_from_vertex(3)
    print(f"✓ DFS_from_vertex(3): {dfs_order2}\n")
    
    # ========== Test Find Path ==========
    print("TEST 9: Find Path (Shortest Path)")
    
    path = g.find_path(1, 5)
    print(f"✓ find_path(1, 5): {path}")
    
    path2 = g.find_path(1, 4)
    print(f"✓ find_path(1, 4): {path2}")
    
    # Non-existent path
    path3 = g.find_path(5, 1)
    print(f"✓ find_path(5, 1): {path3} (empty, no path in directed graph)\n")
    
    # ========== Test Is Connected ==========
    print("TEST 10: Is Connected")
    
    connected = g.is_connected()
    print(f"✓ is_connected(): {connected}")
    
    # Create disconnected graph to test
    g_disconnected = Graph(directed=True)
    g_disconnected.insert_vertex(10)
    g_disconnected.insert_vertex(11)
    g_disconnected.insert_vertex(12)
    g_disconnected.insert_edge(10, 11)
    connected2 = g_disconnected.is_connected()
    print(f"✓ is_connected() on disconnected graph: {connected2}\n")
    
    # ========== Test Topological Sort ==========
    print("TEST 11: Topological Sort")
    
    topo = g.topological_sort()
    print(f"✓ topological_sort(): {topo}\n")
    
    # ========== Test Transpose ==========
    print("TEST 12: Transpose (Reverse Graph)")
    
    gt = g.transpose()
    print(f"✓ transpose(): Created graph with {gt.num_vertices()} vertices, {gt.num_edges()} edges")
    
    # Verify edges are reversed
    orig_edge = g.get_edge(1, 2)
    trans_edge = gt.get_edge(2, 1)
    print(f"✓ Original has edge 1->2: {orig_edge is not None}")
    print(f"✓ Transpose has edge 2->1: {trans_edge is not None}")
    print(f"✓ Transpose does NOT have edge 1->2: {gt.get_edge(1, 2) is None}\n")
    
    # ========== Test Strongly Connected Components ==========
    print("TEST 13: Strongly Connected Components")
    
    sccs = g.strongly_connected_components()
    print(f"✓ strongly_connected_components(): Found {len(sccs)} components")
    for i, scc in enumerate(sccs, 1):
        print(f"  Component {i}: {scc}")
    
    # Create graph with actual SCC
    g_scc = Graph(directed=True)
    g_scc.insert_edge(1, 2)
    g_scc.insert_edge(2, 3)
    g_scc.insert_edge(3, 1)  # Creates cycle 1-2-3-1
    g_scc.insert_edge(3, 4)
    sccs2 = g_scc.strongly_connected_components()
    print(f"✓ SCC on graph with cycle: {sccs2}\n")
    
    # ========== Test Remove Operations ==========
    print("TEST 14: Remove Operations")
    
    # Count before removal
    print(f"Before removal: {g.num_vertices()} vertices, {g.num_edges()} edges")
    
    # remove_edge
    g.remove_edge(e6)
    print(f"✓ remove_edge(2->5): Now {g.num_edges()} edges")
    
    # remove_vertex
    g.remove_vertex(7)
    print(f"✓ remove_vertex(7): Now {g.num_vertices()} vertices, {g.num_edges()} edges")
    
    # Remove with visit_id
    g.remove_vertex(6)
    print(f"✓ remove_vertex(6): Now {g.num_vertices()} vertices, {g.num_edges()} edges\n")
    
    # ========== Test Vertex Class Methods ==========
    print("TEST 15: Vertex Class Methods")
    
    # get_element
    v_elem = v1.get_element()
    print(f"✓ vertex.get_element(): {v_elem}")
    
    # __str__
    v_str = str(v1)
    print(f"✓ vertex.__str__(): {v_str}")
    
    # Vertex properties
    print(f"✓ vertex.visit_id: {v1.visit_id}")
    print(f"✓ vertex.color: {v1.color}")
    print(f"✓ vertex.distance: {v1.distance}")
    print(f"✓ vertex.predecessor: {v1.predecessor}")
    print(f"✓ vertex.discovery_time: {v1.discovery_time}")
    print(f"✓ vertex.finish_time: {v1.finish_time}\n")
    
    print("✓ ALL GRAPH METHODS TESTED SUCCESSFULLY!")

if __name__ == "__main__":
    test_graph_all_methods()
