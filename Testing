storage = DataStorage("patient_visits.csv")
storage.load_data()

print("STEP 2: BUILD AVLs (patient, doctor, cost, visit_id)")
index = IndexManager()
index.build(storage.get_all())

print("Find by patient", index.find_by_patient(101))
print("Find by cost", index.find_by_cost(35000.0))
print("Find by doc",index.find_by_doctor(12))
