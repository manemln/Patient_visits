class Vertex:
    def __init__(self, visit_id, element=None):
        self.visit_id = visit_id
        self.element = element
        self.color = "white"
        self.distance = float('inf')
        self.predecessor = None
        self.discovery_time = 0
        self.finish_time = 0

class Edge:
    def __init__(self, u, v, element=None):
        self.origin = u
        self.destination = v
        self.element = element

    def endpoints(self):
        return self.origin, self.destination
    

class Graph:
    def __init__(self, directed=True):
        self.directed = directed
        self.vertices = {}   # {visit_id: Vertex}
        self.outgoing = {}   # {Vertex: {Vertex: Edge}}
        self.incoming = {}   # {Vertex: {Vertex: Edge}}

    # ---------------- Basic Graph Operations ----------------
    def insert_vertex(self, visit_id, element=None):
        if visit_id in self.vertices:
            return self.vertices[visit_id]
        v = Vertex(visit_id, element)
        self.vertices[visit_id] = v
        self.outgoing[v] = {}
        self.incoming[v] = {}
        return v

    def insert_edge(self, u, v, element=None):
        if isinstance(u, int):
            u = self.vertices.get(u) or self.insert_vertex(u)
        if isinstance(v, int):
            v = self.vertices.get(v) or self.insert_vertex(v)

        if v in self.outgoing[u]:
            return self.outgoing[u][v]

        e = Edge(u, v, element)
        self.outgoing[u][v] = e
        self.incoming[v][u] = e
        return e

    def num_vertices(self):
        return len(self.vertices)

    def num_edges(self):
        return sum(len(edges) for edges in self.outgoing.values())

    def get_vertices(self):
        return list(self.vertices.values())

    def get_edges(self):
        edges = []
        for vertex_edges in self.outgoing.values():
            edges.extend(vertex_edges.values())
        return edges

    def outgoing_edges(self, v):
        if isinstance(v, int):
            v = self.vertices.get(v)
        return self.outgoing.get(v, {})

    def incoming_edges(self, v):
        if isinstance(v, int):
            v = self.vertices.get(v)
        return self.incoming.get(v, {})

    # ---------------- Traversals ----------------
    def BFS(self, start_visit_id):
        for vertex in self.vertices.values():
            vertex.color = "white"
            vertex.distance = float('inf')
            vertex.predecessor = None

        start = self.vertices.get(start_visit_id)
        if start is None:
            return {}

        start.color = "gray"
        start.distance = 0
        start.predecessor = None

        queue = [start]
        distances = {start.visit_id: 0}

        while queue:
            u = queue.pop(0)
            for v in self.outgoing[u]:
                if v.color == "white":
                    v.color = "gray"
                    v.distance = u.distance + 1
                    v.predecessor = u
                    distances[v.visit_id] = v.distance
                    queue.append(v)
            u.color = "black"

        return distances

    def DFS(self):
        for vertex in self.vertices.values():
            vertex.color = "white"
            vertex.predecessor = None
            vertex.discovery_time = 0
            vertex.finish_time = 0

        time = [0]
        times = {}

        def DFS_visit(u):
            time[0] += 1
            u.discovery_time = time[0]
            u.color = "gray"
            for v in self.outgoing[u]:
                if v.color == "white":
                    v.predecessor = u
                    DFS_visit(v)
            u.color = "black"
            time[0] += 1
            u.finish_time = time[0]
            times[u.visit_id] = (u.discovery_time, u.finish_time)

        for vertex in self.vertices.values():
            if vertex.color == "white":
                DFS_visit(vertex)

        return times

    # ---------------- Pathfinding ----------------
    def find_path(self, start_visit_id, end_visit_id):
        self.BFS(start_visit_id)
        end = self.vertices.get(end_visit_id)
        if end is None or end.distance == float('inf'):
            return []

        path = []
        current = end
        while current:
            path.append(current.visit_id)
            current = current.predecessor
        return path[::-1]

    # ---------------- Strongly Connected Components ----------------
    def transpose(self):
        gt = Graph(directed=self.directed)
        for vid, vertex in self.vertices.items():
            gt.insert_vertex(vid, vertex.element)
        for edge in self.get_edges():
            u, v = edge.endpoints()
            gt.insert_edge(v.visit_id, u.visit_id, edge.element)
        return gt

    def strongly_connected_components(self):
        times = self.DFS()
        gt = self.transpose()
        for vertex in gt.vertices.values():
            vertex.color = "white"

        sccs = []

        def DFS_visit(u, component):
            u.color = "gray"
            component.append(u.visit_id)
            for v in gt.outgoing[u]:
                if v.color == "white":
                    DFS_visit(v, component)
            u.color = "black"

        sorted_vertices = sorted(times.items(), key=lambda x: x[1][1], reverse=True)
        for vid, _ in sorted_vertices:
            vertex = gt.vertices[vid]
            if vertex.color == "white":
                component = []
                DFS_visit(vertex, component)
                sccs.append(component)
        return sccs



class GraphManager:
    def __init__(self):
        self.graph = Graph(directed=True)
        self.storage = None

    def build_from_records(self, storage, index_manager):
        self.storage = storage
        for visit_id, record in storage.items():
            self.graph.insert_vertex(visit_id, record)

        for visit_id, record in storage.items():
            patient_id = record['patient_id']
            curr_doc = record['doctor_id']
            ref_doc = record.get('referral_doctor')
            if ref_doc and ref_doc != curr_doc:
                for other_vid in index_manager.find_by_patient(patient_id):
                    if other_vid == visit_id:
                        continue
                    other_record = storage[other_vid]
                    if other_record['doctor_id'] == ref_doc:
                        self.graph.insert_edge(visit_id, other_vid, {
                            "patient_id": patient_id,
                            "original_doctor": curr_doc,
                            "referral_doctor": ref_doc
                        })
                        break

    def find_patient_journey(self, patient_id):
        journey = []
        for vid, record in self.storage.items():
            if record['patient_id'] == patient_id:
                journey.append({
                    'visit_id': vid,
                    'doctor_id': record['doctor_id'],
                    'department': record['department'],
                    'diagnosis': record['diagnosis'],
                    'referral_doctor': record.get('referral_doctor')
                })
        return sorted(journey, key=lambda x: x['visit_id'])

    def find_doctor_referral_network(self, doctor_id, depth=1):
        network = set()
        for vid, record in self.storage.items():
            if record['doctor_id'] == doctor_id and record.get('referral_doctor'):
                network.add(record['referral_doctor'])
        if depth > 1:
            extended = set(network)
            for d in network:
                extended.update(self.find_doctor_referral_network(d, depth-1))
            return extended
        return network

    def add_referral(self, from_vid, to_vid, referral_doctor=None):
        self.graph.insert_edge(from_vid, to_vid, {"referral_doctor": referral_doctor})

    def find_referral_chain(self, visit_id):
        vertex = self.graph.vertices.get(visit_id)
        if not vertex:
            return []
        chain = []
        visited = set()
        current = vertex
        while current and current.visit_id not in visited:
            chain.insert(0, current.visit_id)
            visited.add(current.visit_id)
            incoming = self.graph.incoming_edges(current)
            if not incoming:
                break
            current = next(iter(incoming.keys()))
        return chain




